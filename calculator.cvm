let op=input;
let a=input;
let b=input;

if(op==1){
    print a+b;
}else{
    if(op==2){
        print a-b;
    }else{
        if(op==3){
            print a*b;
        }else{
            if(op==4){
                print a/b;
            }else{
                print 0;
            }
        }
    }
}